<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Dosya Takip Sistemi</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --glass: rgba(255, 255, 255, 0.08);
            --glass-border: rgba(255, 255, 255, 0.15);
            --primary: #6366f1;
            --accent: #10b981;
            --bg: #0f172a;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; -webkit-tap-highlight-color: transparent; }

        body {
            background: radial-gradient(circle at top right, #1e293b, #0f172a);
            color: #f8fafc;
            min-height: 100vh;
            padding: 16px;
            padding-top: env(safe-area-inset-top);
        }

        /* Liquid Glass Progress Card */
        .glass-header {
            position: sticky;
            top: 10px;
            z-index: 1000;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid var(--glass-border);
            border-radius: 28px;
            padding: 24px;
            margin-bottom: 24px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
        }

        .percentage {
            font-size: 3.2rem;
            font-weight: 800;
            text-align: center;
            background: linear-gradient(135deg, #818cf8, #c084fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 5px;
        }

        .stats-text {
            text-align: center;
            font-size: 0.85rem;
            color: #94a3b8;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .progress-bar-bg {
            height: 10px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 20px;
            margin-top: 15px;
            overflow: hidden;
        }

        .progress-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, #4f46e5, #9333ea);
            width: 0%;
            transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
            box-shadow: 0 0 15px rgba(99, 102, 241, 0.5);
        }

        /* Input Section */
        .action-area {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            border-radius: 22px;
            padding: 20px;
            margin-bottom: 25px;
        }

        .input-row { display: grid; grid-template-columns: 1.5fr 1fr; gap: 12px; margin-bottom: 12px; }

        input {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid var(--glass-border);
            padding: 14px;
            border-radius: 14px;
            color: white;
            font-size: 15px;
            width: 100%;
            outline: none;
        }

        input:focus { border-color: var(--primary); }

        .btn-main {
            background: var(--primary);
            color: white;
            border: none;
            padding: 16px;
            border-radius: 14px;
            width: 100%;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
        }

        /* List Styling */
        .tabs { display: flex; gap: 10px; margin-bottom: 18px; }
        .tab {
            flex: 1; padding: 12px; text-align: center;
            background: rgba(255,255,255,0.03);
            border-radius: 12px; font-size: 0.85rem; cursor: pointer;
            border: 1px solid transparent; transition: 0.3s;
            color: #94a3b8;
        }
        .tab.active { background: var(--glass); border-color: var(--primary); color: white; font-weight: 600; }

        .file-card {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 18px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            animation: slideUp 0.4s ease-out;
        }

        @keyframes slideUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

        .file-info h4 { font-size: 1.15rem; margin-bottom: 4px; color: #f1f5f9; }
        .file-info p { font-size: 0.85rem; color: #64748b; }

        .item-actions { display: flex; gap: 12px; }
        .btn-circle {
            width: 46px; height: 46px; border-radius: 14px;
            border: none; color: white; display: flex;
            align-items: center; justify-content: center; cursor: pointer;
            transition: transform 0.2s;
        }
        .btn-circle:active { transform: scale(0.9); }
        .btn-done { background: rgba(16, 185, 129, 0.15); color: var(--accent); border: 1px solid rgba(16, 185, 129, 0.2); }
        .btn-del { background: rgba(244, 63, 94, 0.1); color: #f43f5e; border: 1px solid rgba(244, 63, 94, 0.15); }
    </style>
</head>
<body>

    <div class="glass-header">
        <div class="percentage" id="percDisplay">%0,00</div>
        <div class="stats-text">
            KARAR: <span id="resolvedCount">661</span> / 1147 DOSYA
        </div>
        <div class="progress-bar-bg">
            <div class="progress-bar-fill" id="progressBar"></div>
        </div>
    </div>

    <div class="action-area">
        <div class="input-row">
            <input type="text" id="fNum" placeholder="Dosya No">
            <input type="date" id="fDate">
        </div>
        <button class="btn-main" onclick="addFile()">
            <i data-lucide="plus-circle"></i> Yeni Kayıt Ekle
        </button>
    </div>

    <div class="tabs">
        <div class="tab active" id="tabPending" onclick="switchTab('pending')">Bekleyenler</div>
        <div class="tab" id="tabDone" onclick="switchTab('resolved')">Karar Verilenler</div>
    </div>

    <div id="fileList"></div>

    <script>
        const TOTAL_FILES = 1147;
        const BASE_RESOLVED = 661;

        // EKSİKSİZ BAŞLANGIÇ VERİ SETİ
        // Excel listenizdeki verileri buraya bu formatta ekledim.
        // Tarihi olmayanların date kısmını "" bırakabilirsiniz.
        const defaultFiles = [
            { id: 1001, num: "2024/1", date: "2024-01-01", year: "2024", status: "pending" },
            { id: 1002, num: "2024/2", date: "", year: "2024", status: "pending" },
            { id: 1003, num: "2024/3", date: "2024-01-15", year: "2024", status: "pending" },
            // Buraya Excel'deki tüm satırları eklemeye devam edebilirsiniz.
        ];

        let files = JSON.parse(localStorage.getItem('lawFilesV2'));
        
        if (!files) {
            files = defaultFiles;
            localStorage.setItem('lawFilesV2', JSON.stringify(files));
        }

        let currentTab = 'pending';

        function render() {
            const list = document.getElementById('fileList');
            list.innerHTML = '';
            
            const filtered = files.filter(f => f.status === currentTab);
            const resolvedCount = files.filter(f => f.status === 'resolved').length;
            const currentTotalResolved = BASE_RESOLVED + resolvedCount;
            const perc = (currentTotalResolved / TOTAL_FILES * 100).toFixed(2);

            document.getElementById('percDisplay').innerText = `%${perc.replace('.', ',')}`;
            document.getElementById('resolvedCount').innerText = currentTotalResolved;
            document.getElementById('progressBar').style.width = `${perc}%`;

            if(filtered.length === 0) {
                list.innerHTML = '<p style="text-align:center; color:#64748b; margin-top:20px;">Kayıt bulunamadı.</p>';
            }

            filtered.forEach(f => {
                const card = document.createElement('div');
                card.className = 'file-card';
                card.innerHTML = `
                    <div class="file-info" onclick="editFile(${f.id})">
                        <h4>${f.num}</h4>
                        <p>${f.date ? formatDate(f.date) : 'Tarih Girilmedi'} ${f.year ? '• ' + f.year : ''}</p>
                    </div>
                    <div class="item-actions">
                        <button class="btn-circle btn-done" onclick="toggleStatus(${f.id})">
                            <i data-lucide="${f.status === 'pending' ? 'check' : 'undo-2'}"></i>
                        </button>
                        <button class="btn-circle btn-del" onclick="deleteFile(${f.id})">
                            <i data-lucide="trash-2"></i>
                        </button>
                    </div>
                `;
                list.appendChild(card);
            });
            lucide.createIcons();
        }

        function formatDate(dateStr) {
            const d = new Date(dateStr);
            return d.toLocaleDateString('tr-TR');
        }

        function addFile() {
            const num = document.getElementById('fNum').value;
            const date = document.getElementById('fDate').value;
            if(!num) return alert("Dosya numarası girmelisiniz!");

            files.push({
                id: Date.now(),
                num: num,
                date: date,
                year: date ? new Date(date).getFullYear() : "",
                status: 'pending'
            });
            save();
            document.getElementById('fNum').value = '';
            document.getElementById('fDate').value = '';
            render();
        }

        function toggleStatus(id) {
            files = files.map(f => f.id === id ? {...f, status: f.status === 'pending' ? 'resolved' : 'pending'} : f);
            save();
            render();
        }

        function deleteFile(id) {
            if(confirm('Bu dosyayı listeden çıkarmak istiyor musunuz?')) {
                files = files.filter(f => f.id !== id);
                save();
                render();
            }
        }

        function editFile(id) {
            const f = files.find(x => x.id === id);
            const newNum = prompt("Dosya Numarasını Düzenle:", f.num);
            if(newNum !== null && newNum !== "") {
                f.num = newNum;
                save();
                render();
            }
        }

        function switchTab(t) {
            currentTab = t;
            document.getElementById('tabPending').classList.toggle('active', t === 'pending');
            document.getElementById('tabDone').classList.toggle('active', t === 'resolved');
            render();
        }

        function save() { localStorage.setItem('lawFilesV2', JSON.stringify(files)); }

        render();
    </script>
</body>
</html>
